{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "KC_DIR=\"${KISS_CLAW_DIR:-.kiss-claw}\"; mkdir -p \"${KISS_CLAW_AGENTS_DIR:-$KC_DIR/agents}\" \"${KISS_CLAW_PROJECT_DIR:-$KC_DIR/project}\" \"${KISS_CLAW_SESSIONS_DIR:-$KC_DIR/sessions}\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|str_replace_based_edit_tool|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/agent-suggest.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh ."
          }
        ]
      }
    ]
  }
}
